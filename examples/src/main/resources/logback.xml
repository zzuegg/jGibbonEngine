<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} -- %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

    <!-- Enable TRACE for WebGPU API tracing -->
    <logger name="dev.engine.graphics.webgpu.TracingWgpuBindings" level="TRACE"/>
</configuration>
